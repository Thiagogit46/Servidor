<!-- ================================================ -->
<!-- VIEW: Cadastrar Novo Carro (CREATE)              -->
<!-- Apenas administradores acessam esta página       -->
<!-- ================================================ -->

<%- include('../partials/header') %>

<div class="form-container">
  <h1>➕ Anunciar Novo Carro</h1>

  <!-- EJS: Exibe mensagem de erro se houver -->
  <% if (erro) { %>
    <div class="alert alert-erro"><%= erro %></div>
  <% } %>

  <!-- Formulário envia para POST /carros/novo -->
  <form action="/carros/novo" method="POST">

    <div class="form-group">
      <label>Marca *</label>
      <input type="text" name="marca" placeholder="Ex: Toyota" required>
    </div>

    <div class="form-group">
      <label>Modelo *</label>
      <input type="text" name="modelo" placeholder="Ex: Corolla" required>
    </div>

    <div class="form-group">
      <label>Ano *</label>
      <input type="number" name="ano" placeholder="Ex: 2022"
             min="1900" max="<%= new Date().getFullYear() + 1 %>" required>
    </div>

    <div class="form-group">
      <label>Preço (R$) *</label>
      <input type="number" name="preco" placeholder="Ex: 75000" min="0" required>
    </div>

    <div class="form-group">
      <label>Quantidade Disponível *</label>
      <input type="number" name="qtde_disponivel" placeholder="Ex: 3" min="1" required>
    </div>

    <div class="form-actions">
      <a href="/carros" class="btn btn-secundario">Cancelar</a>
      <button type="submit" class="btn btn-primary">💾 Cadastrar Carro</button>
    </div>

  </form>
</div>

<%- include('../partials/footer') %>
