<!-- ================================================ -->
<!-- VIEW: Login (READ - busca usuário no banco)      -->
<!-- ================================================ -->

<%- include('../partials/header') %>

<div class="form-container form-pequeno">
  <h1>🔑 Entrar na Conta</h1>

  <!-- EJS: Exibe erro de login se houver -->
  <% if (erro) { %>
    <div class="alert alert-erro"><%= erro %></div>
  <% } %>

  <!-- Formulário envia para POST /usuarios/login -->
  <form action="/usuarios/login" method="POST">

    <div class="form-group">
      <label>Login</label>
      <input type="text" name="login" placeholder="Seu login" required>
    </div>

    <div class="form-group">
      <label>Senha</label>
      <input type="password" name="senha" placeholder="Sua senha" required>
    </div>

    <button type="submit" class="btn btn-primary btn-block">Entrar</button>

  </form>

  <p class="link-alternativo">
    Não tem conta? <a href="/usuarios/cadastro">Cadastre-se aqui</a>
  </p>

  <!-- Dica para o professor/avaliador -->
  <div class="dica-admin">
    <strong>💡 Dica:</strong> Para criar um admin, cadastre um usuário e
    altere <code>isAdmin: true</code> direto no MongoDB.
  </div>

</div>

<%- include('../partials/footer') %>
